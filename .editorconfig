root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{png,jpg,jpeg,wav,ogg,mp3,ttf,otf,woff,woff2,ico}]
end_of_line = unset
charset = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
