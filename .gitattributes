# Normalize all text files to LF
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.wav binary
*.ogg binary
*.mp3 binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.ico binary

# Godot binary resources
*.import binary
*.tres text eol=lf
*.tscn text eol=lf
*.godot text eol=lf
*.gd text eol=lf
