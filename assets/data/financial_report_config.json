{
  "version": "1.0",
  "description": "FinancialReportSystem tuning constants. See design/gdd/financial-report-system.md §7",

  "reportCycleSeasons": 3,
  "fiscalYearStartSeason": 1,
  "reportTypeSequence": ["Q1", "H1", "Q3", "Annual"],

  "preliminaryEarnings": {
