  "reportDayMax": 18,
  "analystDayMin": 3,
  "analystDayMax": 10,
  "rumorFireTickInDay": 40,
  "rumorFakerate": 0.30,

  "roeNewsThreshold": 0.03,
  "surpriseThreshold": 0.05,
  "shockThreshold": 0.05,
  "consensusUncertaintyMax": 0.08,
  "uncertaintyDecay": 8.0,
  "sectorRippleRatio": 0.30,
  "sectorNoise": 0.03,
  "stockNoise": 0.02,
  "roeMin": -0.30,
  "roeMax": 0.50,
  "perNegativeSentinel": -1.0,
  "roeDriftScale": 0.04,
  "sectorRippleImpact": 0.06,
