[configuration]
entry_symbol = "markov_generator_init"
compatibility_minimum = "4.3"
reloadable = false

[libraries]
; Windows — built with: scons platform=windows target=template_release arch=x86_64
windows.release.x86_64 = "res://gdextension/bin/windows/libmarkov_generator.windows.template_release.x86_64.dll"
windows.debug.x86_64   = "res://gdextension/bin/windows/libmarkov_generator.windows.template_debug.x86_64.dll"

; Android ARM64 — built with: scons platform=android target=template_release arch=arm64
android.release.arm64  = "res://gdextension/bin/android/libmarkov_generator.android.template_release.arm64.so"
android.debug.arm64    = "res://gdextension/bin/android/libmarkov_generator.android.template_debug.arm64.so"

; iOS ARM64 — built with: scons platform=ios target=template_release arch=arm64
ios.release.arm64      = "res://gdextension/bin/ios/libmarkov_generator.ios.template_release.arm64.dylib"
ios.debug.arm64        = "res://gdextension/bin/ios/libmarkov_generator.ios.template_debug.arm64.dylib"

; Web (Emscripten) — NOT SUPPORTED. See ADR-024 §7.
