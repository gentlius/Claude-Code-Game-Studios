window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[accessibility]

## TD-07: reduced_motion — if true, all UI Tweens skip animation and jump to final value.
## Toggle in Project Settings > Accessibility > Reduced Motion.
reduced_motion=false

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.96, 0.96, 0.97, 1)
