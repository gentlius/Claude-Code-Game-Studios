; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited.

[application]

config/name="Seed Money"
config/name_localized={
"ko": "시드머니"
}
config/description="Real-time stock investment simulation game"
run/main_scene="res://src/ui/GameMain.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameClock="*res://src/core/game_clock.gd"
StockDatabase="*res://src/core/stock_database.gd"
CurrencySystem="*res://src/core/currency_system.gd"
PriceEngine="*res://src/gameplay/price_engine.gd"
NewsEventSystem="*res://src/gameplay/news_event_system.gd"
PortfolioManager="*res://src/gameplay/portfolio_manager.gd"
OrderEngine="*res://src/gameplay/order_engine.gd"
XpSystem="*res://src/gameplay/xp_system.gd"
SkillTree="*res://src/gameplay/skill_tree.gd"
AiCompetitor="*res://src/gameplay/ai_competitor.gd"
SeasonManager="*res://src/gameplay/season_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[accessibility]

## TD-07: reduced_motion — if true, all UI Tweens skip animation and jump to final value.
## Toggle in Project Settings > Accessibility > Reduced Motion.
reduced_motion=false

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.96, 0.96, 0.97, 1)
